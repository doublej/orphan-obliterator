{
  "name": "orphan-obliterator",
  "version": "0.1.0",
  "description": "Prevent orphaned words on the last line of HTML elements",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target browser && tsc --emitDeclarationOnly --outDir dist",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "keywords": ["orphan", "widow", "typography", "text", "nbsp", "dom"],
  "author": "JJ",
  "repository": {
    "type": "git",
    "url": "https://github.com/doublej/orphan-obliterator.git"
  },
  "license": "MIT"
}
